            <column caption='Market Entry Quadrant' datatype='string' name='[Calculation_1424183612698626]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [population] &gt;= [Calculation_1424183612428288]&#13;&#10;AND [places_per_10k_people] &lt; [Calculation_1424183612579841]&#13;&#10;THEN &quot;High Demand / Low Competition&quot;&#13;&#10;&#13;&#10;ELSEIF [population] &gt;= [Calculation_1424183612428288]&#13;&#10;AND [places_per_10k_people] &gt;= [Calculation_1424183612579841]&#13;&#10;THEN &quot;High Demand / High Competition&quot;&#13;&#10;&#13;&#10;ELSEIF [population] &lt; [Calculation_1424183612428288]&#13;&#10;AND [places_per_10k_people] &lt; [Calculation_1424183612579841]&#13;&#10;THEN &quot;Low Demand / Low Competition&quot;&#13;&#10;&#13;&#10;ELSE &quot;Low Demand / High Competition&quot;&#13;&#10;END' />
            </column>

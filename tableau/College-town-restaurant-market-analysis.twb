        </calculation>
      </column>
      <column caption='Archetype' datatype='string' name='[Calculation_1064368271790082]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF [Calculation_1064368270913536] &gt;= 0 AND [Calculation_1064368271585281] &gt;= 0 THEN &quot;A: Concentrated + High Digital&quot;&#13;&#10;ELSEIF [Calculation_1064368270913536] &gt;= 0 AND [Calculation_1064368271585281] &lt; 0 THEN &quot;B: Concentrated + Low Digital&quot;&#13;&#10;ELSEIF [Calculation_1064368270913536] &lt; 0 AND [Calculation_1064368271585281] &gt;= 0 THEN &quot;C: Fragmented + High Digital&quot;&#13;&#10;ELSE &quot;D: Fragmented + Low Digital&quot;&#13;&#10;END'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Global Median Population' datatype='real' name='[Calculation_1424183612428288]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED : MEDIAN([population]) }' />

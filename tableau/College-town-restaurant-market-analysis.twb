      <aliases enabled='yes' />
      <column caption='z_HHI' datatype='real' name='[Calculation_1064368270913536]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='(SUM([brand_hhi]) - WINDOW_AVG(SUM([brand_hhi])))&#13;&#10;/&#13;&#10;WINDOW_STDEV(SUM([brand_hhi]))'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='z_Website' datatype='real' name='[Calculation_1064368271585281]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='(SUM([pct_has_website]) - WINDOW_AVG(SUM([pct_has_website])))&#13;&#10;/&#13;&#10;WINDOW_STDEV(SUM([pct_has_website]))'>
